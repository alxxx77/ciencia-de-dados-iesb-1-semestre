        "plt.plot(x, y, 'D-', color='green', label=\"Dados 1\", linewidth=2) ##ro, ro--, r+, rD- <-- também posso utilizar marcadores já indicando a cor desejada\n",
        "plt.plot(x[::-1], y, '-', color='red', label=\"Dados 2\", marker='D') ## Mostrar o marker substituindo o D ao lado de '-'\n",
        "\n",
        "plt.xticks([1, 2, 3, 4, 5], ['A', 'B', 'C', 'D', 'E'])\n",
        "plt.yticks([2, 6, 10], ['Baixo', 'Médio', 'Alto'])\n",
        "plt.legend()\n",
        "\n",
        "plt.axis(xmin=-1, xmax=10, ymin=0, ymax=12) # Usar o valor \"auto\" e \"square\"\n",
        "\n",
        "plt.show()"
      ]
    },
