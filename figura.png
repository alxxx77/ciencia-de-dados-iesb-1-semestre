      "source": [
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "x = np.linspace(0, 10, 100)\n",
        "pts_destacar = [1, 3, 5, 7, 9]\n",
        "\n",
        "plt.plot(x, np.sin(x), linestyle='--', linewidth=2, label='sen(x)')\n",
        "plt.plot(x, np.cos(x), linestyle='-.', linewidth=2, label='cos(x)')\n",
        "plt.plot(pts_destacar, np.cos(pts_destacar), 'o', markersize=8,\n",
        "         label='Pontos destacados')\n",
        "\n",
        "plt.title(\"Exemplo com três gráficos\")\n",
        "plt.xlabel(\"x\")\n",
        "plt.ylabel(\"y\")\n",
        "plt.grid(True)\n",
        "plt.legend()\n",
        "plt.show()"
      ]
